{
  "model": "graph-wavenet",
  "dataset": "pems-bay",
  "dataset_kwargs": {
    "adjacency_strategy": "auto",
    "zero_as_missing": true,
    "fill_method": "interpolate"
  },
  "model_config": {
    "history_steps": 12,
    "horizon_steps": 12,
    "epochs": 10,
    "batch_size": 64,
    "learning_rate": 0.001,
    "dropout": 0.3,
    "weight_decay": 0.0001,
    "adjtype": "doubletransition",
    "gcn_bool": true,
    "addaptadj": true
  }
}
